# Database Configuration
# Get this from Vercel after creating a Postgres database
# Or from Neon.tech if using their service directly
DATABASE_URL=postgresql://username:password@host:5432/database

# For local development, you can:
# 1. Create a free database at https://neon.tech
# 2. Or use a local PostgreSQL instance
# 3. Or leave empty for build-only (app won't work without it at runtime)
